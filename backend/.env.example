# Copy to .env (or export) for local development.
PORT=8080
GIN_MODE=debug

# Store data locally instead of the container's /data volume.
DB_PATH=./data/memorydrive.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=10

# Workload generation
ENABLE_MEMORY_CACHE=true
CACHE_SIZE_MB=64
BASELINE_MEMORY_MB=16
ENABLE_BACKGROUND_WORKERS=true
WORKER_COUNT=2
WORKER_INTERVAL_SECONDS=10
